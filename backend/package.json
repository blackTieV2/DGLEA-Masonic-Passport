{
  "name": "dglea-masonic-passport-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Backend modular-monolith foundation for DGLEA Masonic Passport",
  "scripts": {
    "dev": "tsx watch src/app/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "test": "jest --config jest.config.cjs --runInBand",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.cjs\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "migrate": "node scripts/migrate.cjs",
    "seed": "node scripts/seed.cjs",
    "fixture:apply": "node scripts/fixture-apply.cjs"
  },
  "dependencies": {
    "pg": "^8.16.3",
    "fastify": "^5.1.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.15.6",
    "@typescript-eslint/eslint-plugin": "^8.31.0",
    "@typescript-eslint/parser": "^8.31.0",
    "eslint": "^9.24.0",
    "jest": "^29.7.0",
    "pg-mem": "^3.0.5",
    "ts-jest": "^29.3.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
